{
  "mcpServers": {
    "infoleg-mcp": {
      "command": "bun",
      "args": [
        "run",
        "start"
      ],
      "cwd": "mcp/infoleg-mcp",
      "env": {
        "INFOLEG_API_BASE_URL": "https://servicios.infoleg.gob.ar/infoleg-internet/api/"
      }
    },
    "arca-mcp": {
      "command": "bun",
      "args": [
        "run",
        "start"
      ],
      "cwd": "mcp/arca-mcp",
      "env": {
        "ARCA_TIMEOUT_MS": "15000"
      }
    }
  }
}
